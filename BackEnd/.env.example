# Server
NODE_ENV=development
PORT=5000

MONGO_DB_NAME=housemate_dev
# Database
MONGODB_URI=mongodb://admin:admin123@localhost:27017/housemate_dev?authSource=admin&directConnection=true

# Seed script target database (must be one of: housemate_dev / housemate_seed / housemate_test)
SEED_MONGODB_URI=mongodb://admin:admin123@localhost:27017/housemate_dev?authSource=admin&directConnection=true

# JWT — keep these long, random, and different from each other
JWT_ACCESS_SECRET=your-access-token-secret-change-this
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this

# Security
BCRYPT_SALT_ROUNDS=12

# CORS
FRONTEND_URL=http://localhost:5173

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com
