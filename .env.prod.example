# ── MongoDB ──────────────────────────────────────────────────────────────
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-this-long-random-password
MONGO_DB_NAME=splitmate

# ── JWT secrets ───────────────────────────────────────────────────────────
# Generate strong random values, e.g.: openssl rand -hex 64
JWT_ACCESS_SECRET=change-this-access-token-secret
JWT_REFRESH_SECRET=change-this-refresh-token-secret
BCRYPT_SALT_ROUNDS=12

# ── CORS / public origin ──────────────────────────────────────────────────
# Set to the HTTPS URL the browser will use.
# For LAN deployment: https://<your-lan-ip>  (e.g. https://192.168.1.42)
# For local single-host testing: https://localhost
FRONTEND_URL=https://localhost

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com
